{
  "name": "chipojo-language",
  "displayName": "Chipojo Language",
  "description": "Syntax highlighting, snippets, icon theme and language support for Chipojo (.chp)",
  "version": "0.3.0",
  "publisher": "luife",
  "license": "MIT",
  "icon": "icon.svg",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Themes"
  ],
  "contributes": {
    "languages": [
      {
        "id": "chipojo",
        "aliases": ["Chipojo", "chipojo"],
        "extensions": [".chp"],
        "configuration": "./language-configuration.json",
        "icon": "icon.svg"
      }
    ],
    "grammars": [
      {
        "language": "chipojo",
        "scopeName": "source.chipojo",
        "path": "./syntaxes/chipojo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "chipojo",
        "path": "./snippets/chipojo.json"
      }
    ],
    "iconThemes": [
      {
        "id": "sybo-chipojo",
        "label": "Sybo Chipojo",
        "path": "./themes/sybo-icon-theme.json"
      }
    ]
  }
}
