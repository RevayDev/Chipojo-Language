{
  "scopeName": "source.chipojo",
  "name": "Chipojo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#methods" },
    { "include": "#property" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.chipojo"
        },
        {
          "match": "//[^\\n]*",
          "name": "comment.line.double-slash.chipojo"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.chipojo"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
          "name": "constant.numeric.chipojo"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|elif|else|while|mientras|for|switch|case|class|public|private|void|try|catch|func|def|return|null|true|false|and|or|not|import|from|as|export|const|var|let|float|string|bool|default)\\b",
          "name": "keyword.control.chipojo"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "match": "\\b(show|abs|input|number|kit)\\b",
          "name": "support.function.builtin.chipojo"
        }
      ]
    },
    "methods": {
      "patterns": [
        {
          "match": "\\.(upper|lower|size|get|push|pop|is_empty|insert|remove|clear|contains|find|reverse|has|set)\\b",
          "name": "support.function.method.chipojo"
        }
      ]
    },
    "property": {
      "patterns": [
        {
          "match": "\\.length\\b",
          "name": "support.variable.property.chipojo"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "(=>|\\+\\+|--|\\+=|-=|\\*=|/=|<=|>=|==|!=|=|\\+|\\-|\\*|/|<|>)",
          "name": "keyword.operator.chipojo"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[{}()\\[\\],.:]",
          "name": "punctuation.chipojo"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
          "name": "variable.other.chipojo"
        }
      ]
    }
  }
}
